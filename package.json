{
  "name": "project-automationexercise",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "pretest": "npm run allure:results:clean",
    "test": "playwright test",
    "pretest:ui": "npm run allure:results:clean",
    "test:ui": "playwright test --ui",
    "pretest:smoke": "npm run allure:results:clean",
    "test:smoke": "playwright test --grep \"@smoke\"",
    "pretest:reg": "npm run allure:results:clean",
    "test:reg": "playwright test --grep \"@regression\"",
    "pretest:grep": "npm run allure:results:clean",
    "test:grep": "playwright test --grep",
    "report": "playwright show-report",
    "allure:results:clean": "node -e \"require('fs').rmSync('allure-results', {recursive:true, force:true})\"",
    "allure:report": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "test:allure": "npm run test && npm run allure:report && npm run allure:open",
    "allure:clean": "node -e \"require('fs').rmSync('.allure', {recursive:true, force:true})\"",
    "ci:allure": "npm run test && npm run allure:report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testmo/testmo-cli": "^1.4.9",
    "@types/node": "^26.0.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.0"
  },
  "dependencies": {
    "@ngneat/falso": "^8.0.2"
  }
}
